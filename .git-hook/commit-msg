#!/bin/bash

# Lấy nội dung commit message
COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat $COMMIT_MSG_FILE)

# Regex quy định chuẩn Conventional Commits
# Cấu trúc: type(scope): message
REGEX="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9_-]+\))?: .+"

# Kiểm tra nếu message không khớp với regex
if [[ ! $COMMIT_MSG =~ $REGEX ]]; then
  echo ""
  echo "❌ LỖI: Commit message của bạn không đúng định dạng!"
  echo "---------------------------------------------------"
  echo "👉 Định dạng chuẩn: <type>(<scope>): <mô tả ngắn>"
  echo "📝 Ví dụ đúng:"
  echo "   feat: add login API"
  echo "   fix(auth): resolve token expiration issue"
  echo ""
  echo "🛠 Các 'type' hợp lệ bao gồm:"
  echo "   feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
  echo "---------------------------------------------------"
  exit 1
fi