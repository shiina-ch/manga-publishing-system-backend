# Documentation only. Spring Boot does not load this file automatically.
DB_URL=jdbc:sqlserver://YOUR_SQL_HOST:1433;databaseName=YOUR_DATABASE;encrypt=true;trustServerCertificate=false
DB_USERNAME=YOUR_DATABASE_USERNAME
DB_PASSWORD=YOUR_DATABASE_PASSWORD

JWT_SECRET=YOUR_BASE64_32_BYTE_JWT_SECRET
JWT_EXPIRATION=86400000

CORS_ALLOWED_ORIGINS=http://localhost:5173
UPLOAD_DIRECTORY=YOUR_ABSOLUTE_UPLOAD_DIRECTORY
UPLOAD_MAX_SIZE=10MB

SERVER_PORT=8386
HIBERNATE_DDL_AUTO=validate
SQL_LOGGING_ENABLED=false
SQL_FORMAT_SQL=false

BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_EMAIL=YOUR_ADMIN_EMAIL
BOOTSTRAP_ADMIN_PASSWORD=YOUR_STRONG_ADMIN_PASSWORD
